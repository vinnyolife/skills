ANTHROPIC_API_KEY=sk-ant-...
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=your-project-id

# Optional: set to 'true' to enable verbose logging
DEBUG=false

# Optional: max number of browsing steps before giving up (default: 10)
# Bumping this up since 10 steps isn't enough for more complex tasks
MAX_STEPS=20

# Optional: timeout in milliseconds for each browsing step (default: 30000)
# Increased to 45s since some pages are slow to load
STEP_TIMEOUT=45000

# Optional: number of retries on network errors (default: 3)
MAX_RETRIES=5
